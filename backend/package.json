{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for Cloud Service Crosswalk Tool",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index-mock.ts",
    "dev:full": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:mock": "node dist/index-mock.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "db:migrate": "npm run build && node dist/scripts/migrate.js",
    "db:seed": "npm run build && node dist/scripts/seed.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "pg": "^8.11.5",
    "redis": "^4.6.13",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/pg": "^8.11.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/uuid": "^9.0.8",
    "@types/jest": "^29.5.12",
    "typescript": "^5.4.3",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.3.1",
    "@typescript-eslint/eslint-plugin": "^7.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}